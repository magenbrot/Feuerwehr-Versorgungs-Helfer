# the API URL
API_URL="http://127.0.0.1:5000/fvh-api"

# the API key you have generated in the GUI
API_KEY=""

# Delay time between two consecutive scans
TOKEN_DELAY="3"

# Disable the NFC reader buzzer
DISABLE_BUZZER="False"

# -1 = take the first available camera or enter the desired camera index for your system
CAMERA_INDEX="-1"

# this defines the "Beschreibung"-field of a transaction in the GUI
MY_NAME="give me a name"

# configure the loglevel, choices are "DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL"
#LOG_LEVEL="DEBUG"
LOG_LEVEL="INFO"

# --- Sound Configuration ---
# Configure sound files for specific events (files must exist in static/sounds/ without extension)
# Set to empty or "none" to disable a sound.
SOUND_SCAN="beep1"
SOUND_SUCCESS="plopp1"
SOUND_ZERO_BALANCE="badumtss"
SOUND_BLOCKED="wah-wah"
SOUND_LOCKED="error"
SOUND_INFO="tagesschau"
SOUND_ERROR="error"

